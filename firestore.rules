// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Settings (public read, admin write only) ───────────────────────────
    match /settings/{docId} {
      allow read: if true;
      allow write: if false; // Only via Admin SDK / Firebase console
    }

    // ── Registrations (anyone can submit, only authenticated users can read) ─
    // TODO: Tighten to admin-only reads once admin roles are set up.
    match /registrations/{docId} {
      allow create: if true; // Anyone can register
      allow read, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Contact messages (anyone can submit, admin read only) ─────────────
    match /contacts/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ── All other documents: deny by default ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
